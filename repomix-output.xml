import { Hono } from "hono";
import { serve } from "bun";
import index from "./index.html"; 

const api = new Hono();

// Fetching real tours from the live WordPress site
api.get("/api/tours", async (c) => {
  try {
    const response = await fetch("https://southethiopiatours.com/wp-json/wp/v2/posts?_embed&per_page=12");
    if (!response.ok) throw new Error("WP API not responding");
    
    const posts = await response.json();

    const tours = posts.map((post: any) => ({
      id: post.id,
      title: post.title.rendered,
      image: post._embedded?.['wp:featuredmedia']?.[0]?.source_url || "/placeholder.jpg",
      description: post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 100) + '...',
      slug: post.slug
    }));

    return c.json({ tours });
  } catch (error) {
    return c.json({ error: "Sync failed", details: error.message }, 500);
  }
});

const server = serve({
  routes: {
    "/api/*": api.fetch,
    "/*": index,
  },
  port: 3000,
});

console.log(`🚀 Headless South Ethiopia Tours Live: ${server.url}`);
